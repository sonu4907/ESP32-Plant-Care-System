// ========== MAIN LOOP ==========
void loop() {
  unsigned long now = millis();
  uptime = now / 1000;
  
  if (WiFi.status() == WL_CONNECTED) Blynk.run();

  if(authenticated && (now - authTimeout > 300000)) authenticated = false;

  static unsigned long lastTimeUpdate = 0;
  if(now - lastTimeUpdate > 60000) {
    updateTime();
    lastTimeUpdate = now;
  }

  if (now - lastBotCheck > 1000) {
    int numNewMessages = bot.getUpdates(bot.last_message_received + 1);
    while (numNewMessages) { handleNewMessages(numNewMessages); numNewMessages = bot.getUpdates(bot.last_message_received + 1); }
    lastBotCheck = now;
  }

  if (now - lastWeatherCheck > 900000) { 
    checkWeather(); 
    lastWeatherCheck = now; 
  }

  if (now - prevMillis > 2000) {
    prevMillis = now;
    readSensors();
    updateAutoMode();
    updateGrowLights();
    storeData();
    broadcastUpdate();
    triggerSmartAlerts();
    
    if (WiFi.status() == WL_CONNECTED) {
      Blynk.virtualWrite(V0, currentWaterLevel);
      Blynk.virtualWrite(V1, currentSoilMoisture);
      Blynk.virtualWrite(V2, pumpState ? 1 : 0);
      Blynk.virtualWrite(V3, autoMode ? 1 : 0);
      Blynk.virtualWrite(V6, lightPercentage);
      Blynk.virtualWrite(V7, currentTemp);
      Blynk.virtualWrite(V8, currentHumidity);
    }
  }
  ws.cleanupClients();
}

void triggerSmartAlerts() {
