const char script_js[] PROGMEM = R"rawliteral(
let socket;
let moistureChart;
let isAuthenticated = false;

let currentSoilMoisture = 0;
let currentTemp = 0;
let currentHumidity = 0;
let precipitationProb = 0;

document.addEventListener('DOMContentLoaded', () => {
    initializeWebSocket();
    initializeChart();
    setupEventListeners();
    checkAuthentication();
    updateLocalTime();
    setInterval(updateLocalTime, 1000);
    loadLocation();
});

function updateLocalTime() {
    const now = new Date();
    document.getElementById('currentTime').textContent = now.toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit' });
    document.getElementById('currentDate').textContent = now.toLocaleDateString('en-IN');
}

function loadLocation() {
    fetch('/getlocation').then(res => res.json()).then(data => {
        document.getElementById('latInput').value = data.lat;
        document.getElementById('lonInput').value = data.lon;
    });
}

function initializeWebSocket() {
    socket = new WebSocket(`ws://${window.location.host}/ws`);
    socket.onmessage = (event) => updateDashboard(JSON.parse(event.data));
    socket.onclose = () => setTimeout(initializeWebSocket, 3000);
}

function initializeChart() {
    const ctx = document.getElementById('moistureChart').getContext('2d');
    moistureChart = new Chart(ctx, {
        type: 'line',
        data: { labels: [], datasets: [{ label: 'Soil Moisture (%)', data: [], borderColor: '#2ecc71', backgroundColor: 'rgba(46, 204, 113, 0.2)', borderWidth: 3, tension: 0.4, fill: true }]},
        options: { responsive: true, maintainAspectRatio: false, scales: { y: { beginAtZero: true, max: 100 } } }
    });
}

function setupEventListeners() {
    document.getElementById('autoMode').addEventListener('change', function() {
        if (!isAuthenticated) { this.checked = true; showLoginModal(); return; }
        fetch(`/mode?set=${this.checked ? 'auto' : 'manual'}`);
    });
    document.getElementById('pumpOn').addEventListener('click', () => isAuthenticated ? fetch('/control?pump=ON') : showLoginModal());
    document.getElementById('pumpOff').addEventListener('click', () => isAuthenticated ? fetch('/control?pump=OFF') : showLoginModal());
    document.getElementById('dryThreshold').addEventListener('input', (e) => document.getElementById('dryValue').textContent = e.target.value + '%');
    document.getElementById('wetThreshold').addEventListener('input', (e) => document.getElementById('wetValue').textContent = e.target.value + '%');
    document.getElementById('lightThreshold').addEventListener('input', (e) => document.getElementById('lightThresholdValue').textContent = e.target.value);
    
    document.getElementById('saveThresholds').addEventListener('click', () => {
        if (!isAuthenticated) return showLoginModal();
        fetch(`/thresholds?dry=${document.getElementById('dryThreshold').value}&wet=${document.getElementById('wetThreshold').value}&light=${document.getElementById('lightThreshold').value}`).then(() => alert('Settings Saved!'));
    });
    
    document.getElementById('saveLocation').addEventListener('click', () => {
        if (!isAuthenticated) return showLoginModal();
        let lat = document.getElementById('latInput').value;
        let lon = document.getElementById('lonInput').value;
        fetch(`/setlocation?lat=${lat}&lon=${lon}`).then(() => alert('Location Saved! Weather will update soon.'));
    });
    
    document.getElementById('loginForm').addEventListener('submit', (e) => {
        e.preventDefault();
        fetch('/login', {
            method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: `password=${encodeURIComponent(document.getElementById('password').value)}`
        }).then(res => res.json()).then(data => {
            if (data.success) {
                isAuthenticated = true; document.getElementById('loginModal').style.display = 'none';
                document.getElementById('autoMode').disabled = false; 
                updateManualControls(!document.getElementById('autoMode').checked);
            } else alert('Invalid password!');
        });
    });
}

function checkAuthentication() {
    fetch('/status').then(res => res.json()).then(data => {
        isAuthenticated = data.authenticated;
        if (isAuthenticated) { 
            document.getElementById('autoMode').disabled = false; 
            updateManualControls(!document.getElementById('autoMode').checked); 
        }
    });
}

function updateDashboard(data) {

  currentSoilMoisture = data.soilMoisture;
currentTemp = data.temperature;
currentHumidity = data.humidity;
precipitationProb = data.precipitationProb;

    document.getElementById('temperature').textContent = data.temperature.toFixed(1);
    document.getElementById('feelsLike').textContent = data.feelsLike.toFixed(1);
    document.getElementById('humidity').textContent = data.humidity;
    document.getElementById('windSpeed').textContent = data.windSpeed.toFixed(1);
    document.getElementById('pressure').textContent = data.pressure.toFixed(0);
    document.getElementById('uvIndex').textContent = data.uvIndex;
    document.getElementById('visibility').textContent = data.visibility.toFixed(1);
    document.getElementById('dewPoint').textContent = data.dewPoint.toFixed(1);
    document.getElementById('moonPhase').textContent = data.moonPhase;
    document.getElementById('rainProb').textContent = data.precipitationProb;
    document.getElementById('weatherDesc').textContent = data.weatherDesc;
    document.getElementById('sunrise').textContent = data.sunrise;
    document.getElementById('sunset').textContent = data.sunset;
    
    const weatherIcon = document.querySelector('.weather-icon i');
    if (data.precipitationProb > 50) weatherIcon.className = 'fas fa-cloud-rain';
    else if (data.weatherDesc.includes('Cloud')) weatherIcon.className = 'fas fa-cloud-sun';
    else weatherIcon.className = 'fas fa-sun';
    
    document.getElementById('waterLevel').textContent = Math.round(data.waterLevel) + '%';
    document.getElementById('waterLevelBar').style.height = data.waterLevel + '%';
    document.getElementById('waterLevelBar').style.background = data.waterLevel < 20 ? '#e74c3c' : data.waterLevel < 50 ? '#f39c12' : '#3498db';
    
    document.getElementById('soilMoisture').textContent = Math.round(data.soilMoisture) + '%';
    document.getElementById('moistureFill').style.width = data.soilMoisture + '%';
    let smStat = document.getElementById('moistureStatus');
    if (data.soilMoisture < 30) { smStat.textContent = '🌵 DRY - Needs Watering'; smStat.className = 'moisture-status status-dry'; document.getElementById('moistureFill').style.background = '#e74c3c'; }
    else if (data.soilMoisture < 70) { smStat.textContent = '😊 NORMAL - Healthy'; smStat.className = 'moisture-status status-normal'; document.getElementById('moistureFill').style.background = '#f39c12'; }
    else { smStat.textContent = '💧 WET - Reduce Watering'; smStat.className = 'moisture-status status-wet'; document.getElementById('moistureFill').style.background = '#27ae60'; }
    
    // LDR LOGIC: Lights ON when light is LOW (currentLightLevel < lightThreshold)
    let lightPercent = Math.round(data.lightLevel);
    document.getElementById('lightLevel').textContent = lightPercent + '%';
    document.getElementById('lightFill').style.width = lightPercent + '%';
    
    let isLightLow = (data.rawLightValue > data.lightThreshold);
    document.getElementById('lightStatus').innerHTML = isLightLow ? '💡 LOW LIGHT - Grow Lights ON' : '☀️ SUFFICIENT LIGHT - Lights OFF';
