  String url = "https://api.open-meteo.com/v1/forecast?latitude=" + userLat + 
               "&longitude=" + userLon + 
               "&current=temperature_2m,relative_humidity_2m,apparent_temperature,precipitation,rain,weather_code,wind_speed_10m,pressure_msl,uv_index,visibility" +
               "&hourly=precipitation_probability" +
               "&daily=sunrise,sunset" +
               "&timezone=Asia/Kolkata&forecast_days=1";
  
  http.begin(url);
  int httpCode = http.GET();
  
  if (httpCode == HTTP_CODE_OK) {
    DynamicJsonDocument doc(8192);
    deserializeJson(doc, http.getString());
    
    JsonObject current = doc["current"];
    currentTemp = current["temperature_2m"].as<float>();
    currentHumidity = current["relative_humidity_2m"].as<int>();
    feelsLike = current["apparent_temperature"].as<float>();
    windSpeed = current["wind_speed_10m"].as<float>();
    pressure = current["pressure_msl"].as<float>();
    uvIndex = current["uv_index"].as<int>();
    visibility = current["visibility"].as<float>() / 1000;
    weatherCode = current["weather_code"].as<int>();
    
    dewPoint = calculateDewPoint(currentTemp, currentHumidity);
    
    JsonArray hourlyProb = doc["hourly"]["precipitation_probability"];
    precipitationProb = 0;
    for(int i = 0; i < 6 && i < hourlyProb.size(); i++) {
      if(hourlyProb[i].as<float>() > precipitationProb) 
        precipitationProb = hourlyProb[i].as<float>();
    }
    
    rainExpected = (precipitationProb >= 30);
    
    JsonArray dailySunrise = doc["daily"]["sunrise"];
    JsonArray dailySunset = doc["daily"]["sunset"];
    if(dailySunrise.size() > 0 && dailySunset.size() > 0) {
      String sunriseStr = dailySunrise[0].as<String>();
      String sunsetStr = dailySunset[0].as<String>();
      sunrise = sunriseStr.substring(11, 16);
      sunset = sunsetStr.substring(11, 16);
    }
    
    struct tm timeinfo;
    if(getLocalTime(&timeinfo, 5000)) {
      moonPhase = getMoonPhaseDescription(timeinfo.tm_mday);
    }
    
    Serial.println("✓ Weather Updated for: " + userLat + ", " + userLon);
  }
  http.end();
}

