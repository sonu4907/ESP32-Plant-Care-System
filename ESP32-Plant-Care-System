  doc["waterLevel"] = currentWaterLevel;
  doc["soilMoisture"] = currentSoilMoisture;
  doc["lightLevel"] = lightPercentage;
  doc["rawLightValue"] = currentLightLevel;
  doc["pumpState"] = pumpState;
  doc["autoMode"] = autoMode;
  doc["rainExpected"] = rainExpected;
  doc["lightState"] = lightState;
  doc["dryThreshold"] = dryThreshold;
  doc["wetThreshold"] = wetThreshold;
  doc["lightThreshold"] = lightThreshold;
  doc["uptime"] = uptime;
  doc["authenticated"] = authenticated;
  doc["temperature"] = currentTemp;
  doc["feelsLike"] = feelsLike;
  doc["humidity"] = currentHumidity;
  doc["windSpeed"] = windSpeed;
  doc["dewPoint"] = dewPoint;
  doc["pressure"] = pressure;
  doc["uvIndex"] = uvIndex;
  doc["visibility"] = visibility;
  doc["moonPhase"] = moonPhase;
  doc["precipitationProb"] = precipitationProb;
  doc["weatherDesc"] = getWeatherDescription(weatherCode);
  doc["sunrise"] = sunrise;
  doc["sunset"] = sunset;
  doc["currentTime"] = currentTime;
  doc["currentDate"] = currentDate;
  
  String status = "System Normal";
  if (currentWaterLevel < lowTankThreshold) status = "⚠️ Water Tank Low!";
  else if (rainExpected) status = "🌧️ Rain Expected - Watering Paused";
  else if (pumpState) status = "💧 Pump Running";
  else if (currentSoilMoisture < dryThreshold && autoMode) status = "🌱 Soil Dry - Pump will start soon";
  else if (currentLightLevel < lightThreshold && autoMode) status = "💡 Low Light - Grow Lights ON";
  doc["status"] = status;

  String output; serializeJson(doc, output); return output;
}

void broadcastUpdate() { ws.textAll(getStatusJSON()); }

void loadSettings() {
  prefs.begin("garden", false);
  dryThreshold = prefs.getFloat("dry", 30.0);
  wetThreshold = prefs.getFloat("wet", 70.0);
  lightThreshold = prefs.getInt("lightThreshold", 1500);
  userLat = prefs.getString("lat", "16.705");
  userLon = prefs.getString("lon", "74.2433");
  autoMode = prefs.getBool("autoMode", true);
  prefs.end();
}

void saveSettings() {
  prefs.begin("garden", false);
  prefs.putFloat("dry", dryThreshold);
  prefs.putFloat("wet", wetThreshold);
  prefs.putInt("lightThreshold", lightThreshold);
  prefs.putBool("autoMode", autoMode);
  prefs.end();
}  for this
