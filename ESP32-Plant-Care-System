void readSensors() {
  // Ultrasonic for water level
  digitalWrite(TRIG_PIN, LOW); delayMicroseconds(2);
  digitalWrite(TRIG_PIN, HIGH); delayMicroseconds(10); digitalWrite(TRIG_PIN, LOW);
  long duration = pulseIn(ECHO_PIN, HIGH, 30000);
  float distance = (duration == 0 ? 30 : duration) * 0.034 / 2;
  if(distance > 30) distance = 30;
  currentWaterLevel = constrain(((30 - distance) / 30) * 100, 0, 100);
  
  // Soil moisture
  int rawMoisture = analogRead(MOISTURE_PIN);
  currentSoilMoisture = constrain(map(rawMoisture, 2800, 800, 0, 100), 0, 100);
  
  // LDR - reading
  currentLightLevel = analogRead(LDR_PIN);
  lightPercentage = map(currentLightLevel, 0, 4095, 100, 0);
  lightPercentage = constrain(lightPercentage, 0, 100);
}

void updateAutoMode() {
  // CORRECTED AUTO WATERING LOGIC:
  // Pump stays ON until soil moisture reaches wet threshold
  if(autoMode) {
    // Turn pump ON when soil is dry, tank not empty, and no rain expected
    if(currentSoilMoisture < dryThreshold && !pumpState && currentWaterLevel > lowTankThreshold && !rainExpected) {
      turnPumpOn();
    }
    // Turn pump OFF when soil moisture reaches or exceeds wet threshold
    else if(currentSoilMoisture >= wetThreshold && pumpState) {
      turnPumpOff();
    }
    // Emergency stop: If tank becomes empty while pump is running
    else if(pumpState && currentWaterLevel <= lowTankThreshold) {
      turnPumpOff();
      if(!alertLowWaterSent) {
        bot.sendMessage(CHAT_ID, "⚠️ *Alert:* Water tank empty! Pump stopped.", "Markdown");
        alertLowWaterSent = true;
      }
    }
  }
}

void updateGrowLights() {
  // CORRECTED LDR LOGIC: Lights ON when light is LOW
  if (autoMode && currentLightLevel > lightThreshold) {
    digitalWrite(LED_RED_PIN, HIGH);
    digitalWrite(LED_BLUE_PIN, HIGH); 
    lightState = true; 
  } else { 
    digitalWrite(LED_RED_PIN, LOW);
    digitalWrite(LED_BLUE_PIN, LOW);
    lightState = false; 
  }
}

void turnPumpOn() { 
  digitalWrite(PUMP_PIN_A, HIGH); 
  digitalWrite(PUMP_PIN_B, LOW); 
  pumpState = true; 
  if (WiFi.status() == WL_CONNECTED) Blynk.virtualWrite(V2, 1);
}

void turnPumpOff() { 
  digitalWrite(PUMP_PIN_A, LOW); 
  digitalWrite(PUMP_PIN_B, LOW); 
  pumpState = false; 
  if (WiFi.status() == WL_CONNECTED) Blynk.virtualWrite(V2, 0);
}

void storeData() {
  dataBuffer[dataIndex] = {millis(), currentWaterLevel, currentSoilMoisture, pumpState};
  dataIndex = (dataIndex + 1) % DATA_BUFFER_SIZE;
  if(dataIndex == 0) bufferFull = true;
}

