  if (currentWaterLevel >= 80.0 && !alertTankFullSent) {
    bot.sendMessage(CHAT_ID, "🌊 *Alert:* Water tank is FULL (" + String(currentWaterLevel, 1) + "%)", "Markdown");
    alertTankFullSent = true;
  } else if (currentWaterLevel < 75.0) alertTankFullSent = false;

  if (currentWaterLevel <= 20.0 && !alertTankEmptySent) {
    bot.sendMessage(CHAT_ID, "⚠️ *Alert:* Water tank is EMPTY (" + String(currentWaterLevel, 1) + "%). Please refill!", "Markdown");
    alertTankEmptySent = true;
  } else if (currentWaterLevel > 25.0) alertTankEmptySent = false;

  if (currentWaterLevel <= lowTankThreshold && !alertLowWaterSent && pumpState) {
    bot.sendMessage(CHAT_ID, "⚠️ *Alert:* Low water level! Pump stopped to prevent damage.", "Markdown");
    alertLowWaterSent = true;
    turnPumpOff();
  } else if (currentWaterLevel > lowTankThreshold + 10) alertLowWaterSent = false;

  if (rainExpected && !alertRainSent) {
    bot.sendMessage(CHAT_ID, "🌧️ *Alert:* Rain expected (" + String(precipitationProb, 0) + "% chance). Auto-watering paused.", "Markdown");
    alertRainSent = true;
  } else if (!rainExpected) alertRainSent = false;

  if (currentTemp < 5 && !alertFreezeSent) {
    bot.sendMessage(CHAT_ID, "❄️ *Alert:* Low temperature detected (" + String(currentTemp, 1) + "°C). Protect your plants!", "Markdown");
    alertFreezeSent = true;
  } else if (currentTemp > 8) alertFreezeSent = false;
}

